# Runtime state -- NOT tracked
state/
logs/
*.tmp
*.pid

# Secrets -- NEVER tracked
config.json

# Derived data -- reconstructable
memory.db
memory.db-wal
memory.db-shm
backups/

# Tracked state:
# AGENT.md, USER.md, MEMORY.md
# jobs.json
# users.json
# hooks/ (generated but version-trackable)
# evolution/ (proposals, learnings, gaps)
